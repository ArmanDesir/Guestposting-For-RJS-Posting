# Never commit real keys. Copy to .env for local runs if needed.

# DEV.to official API
DEVTO_API_KEY=

# Generic Forem instance official API
FOREM_API_KEY=
FOREM_BASE_URL=https://dev.to

# Hashnode official GraphQL API
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Medium official integration token
MEDIUM_TOKEN=
MEDIUM_AUTHOR_ID=

# Tumblr has an official API, but this automation exports manual drafts unless
# an OAuth-backed adapter is added.
TUMBLR_CONSUMER_KEY=
TUMBLR_CONSUMER_SECRET=
TUMBLR_OAUTH_TOKEN=
TUMBLR_OAUTH_SECRET=
